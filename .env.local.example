# Copy this file to .env.local and fill in your values

# Anthropic — server-side only, NEVER expose to the browser
ANTHROPIC_API_KEY=sk-ant-...

# Tavily — used for fast web search on restaurant name lookups (free: 1000 searches/month)
# Get key at: https://app.tavily.com → API Keys
TAVILY_API_KEY=tvly-...

# Supabase — these two are safe to expose (row-level security enforced)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase — server-side only, used for writes from API routes
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App URL — used to generate shareable decode links
# For local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For production (update before deploying):
# NEXT_PUBLIC_APP_URL=https://forkast.app
